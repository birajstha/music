{
  "name": "music",
  "main": "./worker.js",
  "compatibility_date": "2024-01-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "binding": "ASSETS"
  },
  "routes": [
    { "pattern": "music.evanietech.com/*", "zone_name": "evanietech.com" }
  ]
}
